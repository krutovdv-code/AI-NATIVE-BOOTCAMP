---
const currentPath = Astro.url.pathname;
---

<header style="padding: 1.5rem 2rem; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center;">
  <a href="/" style="font-weight: 700; font-size: 1.1rem; text-decoration: none; color: var(--text);">
    AI-NATIVE<span class="mono" style="color: var(--accent);"> BOOTCAMP</span>
  </a>
  <nav style="display: flex; gap: 2rem;">
    <a href="/" class={currentPath === '/' ? 'active' : ''}>Главная</a>
    <a href="/program">Программа</a>
    <a href="/register">Записаться</a>
  </nav>
</header>
